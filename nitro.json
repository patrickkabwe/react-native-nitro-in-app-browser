{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "nitroinappbrowser"
  ],
  "ios": {
    "iosModuleName": "NitroInAppBrowser"
  },
  "android": {
    "androidNamespace": [
      "nitroinappbrowser"
    ],
    "androidCxxLibName": "NitroInAppBrowser"
  },
  "autolinking": {
    "NitroInAppBrowser": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridNitroInAppBrowser"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridNitroInAppBrowser"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}